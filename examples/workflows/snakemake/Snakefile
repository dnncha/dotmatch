configfile: "examples/workflows/snakemake/config.json"

outdir = config.get("outdir", "examples/workflows/snakemake/output")
samples = config["samples"]
metric = config.get("metric", "levenshtein")
indel_window = int(config.get("indel_window", 0))
indel_window_arg = f"--indel-window {indel_window}" if metric == "levenshtein" and indel_window > 0 else ""


rule all:
    input:
        f"{outdir}/counts.mageck.tsv",
        f"{outdir}/summary.json",
        f"{outdir}/sample_qc.tsv",
        f"{outdir}/assay/assay_report.html",
        f"{outdir}/assay/assay_manifest.json",
        f"{outdir}/assay/assay_manifest.summary.tsv",


rule sample_sheet:
    output:
        f"{outdir}/samples.tsv"
    run:
        import os

        os.makedirs(os.path.dirname(output[0]), exist_ok=True)
        with open(output[0], "w", encoding="utf-8") as handle:
            handle.write("sample_id\tfastq\n")
            for sample_id, fastq in samples.items():
                handle.write(f"{sample_id}\t{fastq}\n")


rule dotmatch_crispr_count:
    input:
        library=config["library"],
        samples=f"{outdir}/samples.tsv",
    output:
        counts=f"{outdir}/counts.mageck.tsv",
        summary=f"{outdir}/summary.json",
        sample_qc=f"{outdir}/sample_qc.tsv",
    params:
        guide_start=config["guide_start"],
        guide_length=config["guide_length"],
        k=config.get("k", 1),
        metric=metric,
        indel_window_arg=indel_window_arg,
    shell:
        """
        dotmatch crispr-count \
          --library {input.library} \
          --samples {input.samples} \
          --guide-start {params.guide_start} \
          --guide-length {params.guide_length} \
          --k {params.k} \
          --metric {params.metric} \
          {params.indel_window_arg} \
          --out {output.counts} \
          --summary {output.summary} \
          --sample-qc {output.sample_qc} \
          --ambiguous discard
        """


rule dotmatch_assay_spec:
    output:
        f"{outdir}/assay.toml"
    run:
        import json
        import os

        def toml_string(value):
            return json.dumps(str(value))

        os.makedirs(os.path.dirname(output[0]), exist_ok=True)
        with open(output[0], "w", encoding="utf-8") as handle:
            handle.write("schema_version = 1\n")
            handle.write('status = "ready"\n')
            handle.write('mode = "count"\n')
            handle.write('assay_type = "crispr"\n')
            handle.write(f"targets = {toml_string(config['library'])}\n\n")
            for sample_id, fastq in samples.items():
                handle.write("[[samples]]\n")
                handle.write(f"id = {toml_string(sample_id)}\n")
                handle.write(f"fastq = {toml_string(fastq)}\n\n")
            handle.write("[run]\n")
            handle.write(f"out_dir = {toml_string(f'{outdir}/assay')}\n")
            handle.write("threads = 1\n\n")
            handle.write("[extract]\n")
            handle.write(f"start = {config['guide_start']}\n")
            handle.write(f"length = {config['guide_length']}\n\n")
            handle.write("[assignment]\n")
            handle.write(f"k = {config.get('k', 1)}\n")
            handle.write(f'metric = "{metric}"\n')
            handle.write('ambiguous = "discard"\n')
            if metric == "levenshtein" and indel_window > 0:
                handle.write(f"indel_window = {indel_window}\n")
            handle.write("\n[outputs]\n")
            handle.write('format = "mageck"\n')


rule dotmatch_assay_run:
    input:
        spec=f"{outdir}/assay.toml"
    output:
        report=f"{outdir}/assay/assay_report.html",
        manifest=f"{outdir}/assay/assay_manifest.json",
        manifest_summary=f"{outdir}/assay/assay_manifest.summary.tsv",
        sample_qc=f"{outdir}/assay/sample_qc.tsv",
        crispr_qc_report=f"{outdir}/assay/crispr_qc.html",
        crispr_qc_json=f"{outdir}/assay/crispr_qc.json",
        crispr_qc_summary=f"{outdir}/assay/crispr_qc.summary.tsv",
        counts=f"{outdir}/assay/counts.mageck.tsv",
        summary=f"{outdir}/assay/summary.json",
    shell:
        """
        dotmatch assay run {input.spec}
        """
