nextflow_process {
    name "Test Process DOTMATCH_CRISPR_COUNT"
    script "../main.nf"
    process "DOTMATCH_CRISPR_COUNT"

    test("runs tiny CRISPR fixture") {
        when {
            process {
                """
                input[0] = Channel.of([
                    [id: 'sample_a'],
                    file('examples/workflows/fixtures/sample_a.fastq'),
                    file('examples/workflows/fixtures/crispr_library.csv')
                ])
                input[1] = 0
                input[2] = 4
                input[3] = 1
                input[4] = 'hamming'
                """
            }
        }

        then {
            assert process.success
            assert path(process.out.counts[0][1]).name.endsWith(".counts.mageck.tsv")
            assert path(process.out.sample_qc[0][1]).text.contains("assignment_rate")
            assert path(process.out.versions[0]).name == "versions.yml"
            assert path(process.out.versions[0]).text.contains("dotmatch")
        }
    }
}
