<tool id="dotmatch_assay_run" name="DotMatch AssaySpec run" version="0.1.0+galaxy0" profile="22.05" license="Apache-2.0">
    <description>run a fixed-window DotMatch AssaySpec and emit workflow reports</description>
    <requirements>
        <requirement type="package" version="0.1.0">dotmatch</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
cat > assay.toml <<'ASSAY'
schema_version = 1
status = "ready"
mode = "count"
assay_type = "crispr"
targets = "$library"

[[samples]]
id = "$sample1_label"
fastq = "$sample1_fastq"

[[samples]]
id = "$sample2_label"
fastq = "$sample2_fastq"

[run]
out_dir = "assay_out"
threads = 1

[extract]
start = $guide_start
length = $guide_length

[assignment]
k = $k
metric = "$metric"
ambiguous = "$ambiguous"
#if str($metric) == 'levenshtein' and int($indel_window) > 0
indel_window = $indel_window
#end if

[outputs]
format = "mageck"
ASSAY

dotmatch assay run assay.toml
    ]]></command>
    <inputs>
        <param name="library" type="data" format="csv,tabular,txt" label="Guide library" help="MAGeCK-style CSV or target TSV accepted by DotMatch."/>
        <param name="sample1_fastq" type="data" format="fastq,fastqsanger,fastq.gz,fastqsanger.gz" label="Sample 1 FASTQ"/>
        <param name="sample1_label" type="text" value="sample_1" label="Sample 1 label"/>
        <param name="sample2_fastq" type="data" format="fastq,fastqsanger,fastq.gz,fastqsanger.gz" label="Sample 2 FASTQ"/>
        <param name="sample2_label" type="text" value="sample_2" label="Sample 2 label"/>
        <param name="guide_start" type="integer" value="23" min="0" label="Guide start" help="Zero-based start position of the guide window in each read."/>
        <param name="guide_length" type="integer" value="19" min="1" label="Guide length"/>
        <param name="k" type="integer" value="1" min="0" max="1" label="Edit-distance threshold"/>
        <param name="metric" type="select" label="Metric">
            <option value="levenshtein" selected="true">Levenshtein</option>
            <option value="hamming">Hamming</option>
        </param>
        <param name="indel_window" type="integer" value="1" min="0" max="1" label="Levenshtein indel window" help="Used only when metric is Levenshtein."/>
        <param name="ambiguous" type="select" label="Ambiguous read handling">
            <option value="discard" selected="true">Discard from counts</option>
            <option value="report">Report diagnostics</option>
        </param>
    </inputs>
    <outputs>
        <data name="assay_report" format="html" from_work_dir="assay_out/assay_report.html" label="${tool.name} on ${on_string}: assay report"/>
        <data name="assay_manifest" format="json" from_work_dir="assay_out/assay_manifest.json" label="${tool.name} on ${on_string}: manifest"/>
        <data name="assay_manifest_summary" format="tabular" from_work_dir="assay_out/assay_manifest.summary.tsv" label="${tool.name} on ${on_string}: manifest summary"/>
        <data name="sample_qc" format="tabular" from_work_dir="assay_out/sample_qc.tsv" label="${tool.name} on ${on_string}: sample QC"/>
        <data name="crispr_qc_report" format="html" from_work_dir="assay_out/crispr_qc.html" label="${tool.name} on ${on_string}: CRISPR QC report"/>
        <data name="crispr_qc_json" format="json" from_work_dir="assay_out/crispr_qc.json" label="${tool.name} on ${on_string}: CRISPR QC JSON"/>
        <data name="crispr_qc_summary" format="tabular" from_work_dir="assay_out/crispr_qc.summary.tsv" label="${tool.name} on ${on_string}: CRISPR QC summary"/>
        <data name="counts" format="tabular" from_work_dir="assay_out/counts.mageck.tsv" label="${tool.name} on ${on_string}: counts"/>
        <data name="summary" format="json" from_work_dir="assay_out/summary.json" label="${tool.name} on ${on_string}: summary"/>
    </outputs>
    <tests>
        <test expect_num_outputs="9">
            <param name="library" value="crispr_library.csv"/>
            <param name="sample1_fastq" value="sample_a.fastq"/>
            <param name="sample1_label" value="sample_a"/>
            <param name="sample2_fastq" value="sample_b.fastq"/>
            <param name="sample2_label" value="sample_b"/>
            <param name="guide_start" value="0"/>
            <param name="guide_length" value="4"/>
            <param name="k" value="1"/>
            <param name="metric" value="hamming"/>
            <param name="ambiguous" value="discard"/>
            <output name="assay_report">
                <assert_contents>
                    <has_text text="DotMatch Assay Report"/>
                    <has_text text="Sample QC"/>
                </assert_contents>
            </output>
            <output name="assay_manifest_summary">
                <assert_contents>
                    <has_text text="primary_report"/>
                    <has_text text="autopsy_triggered"/>
                </assert_contents>
            </output>
            <output name="sample_qc">
                <assert_contents>
                    <has_text text="assignment_rate"/>
                    <has_text text="sample_a"/>
                </assert_contents>
            </output>
            <output name="crispr_qc_summary">
                <assert_contents>
                    <has_text text="qc_status"/>
                </assert_contents>
            </output>
            <output name="crispr_qc_report">
                <assert_contents>
                    <has_text text="DotMatch CRISPR QC"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help><![CDATA[
DotMatch AssaySpec is the declarative workflow layer for fixed-window
known-target assays. This example wrapper builds a reviewed `status = "ready"`
count AssaySpec from Galaxy-staged inputs, then exposes the human-readable assay
report, run manifest, manifest summary, sample QC, CRISPR QC, counts, and
DotMatch summary.

This wrapper is intended for local Galaxy installations and workflow testing.
    ]]></help>
</tool>
